om.onclick=e=>{if(e.target===om)closeOM()};document.onkeydown=e=>{if(e.key==='Escape')closeOM()};
of.onsubmit=e=>{e.preventDefault();let ok=true;[{i:'oName',v:x=>x.trim().length>0},{i:'oPhone',v:x=>/^[0-9]{10}$/.test(x.trim())},{i:'oEmail',v:x=>/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(x)},{i:'oAddr',v:x=>x.trim().length>0},{i:'oQty',v:x=>+x>=1&&+x<=100}].forEach(f=>{const inp=$('#'+f.i),g=inp.closest('.fg');if(!f.v(inp.value)){g.classList.add('error');ok=false}else g.classList.remove('error')});if(ok){const pn=$('#oProd').value,pr=$('#oPrice').value,n=$('#oName').value,ph=$('#oPhone').value,em=$('#oEmail').value,ad=$('#oAddr').value,qt=$('#oQty').value;window.open('mailto:sohamdada@gmail.com?subject='+encodeURIComponent('New Order - '+n)+'&body='+encodeURIComponent('ORDER DETAILS\n==================\nProduct: '+pn+'\nPrice: '+pr+'\nQuantity: '+qt+'\n\nCUSTOMER DETAILS\n==================\nName: '+n+'\nPhone: '+ph+'\nEmail: '+em+'\nAddress: '+ad+'\n\n— Somee Beverages Website'),'_blank');of.style.display='none';os.classList.add('show');toast('Order sent to sohamdada@gmail.com! 🎉');setTimeout(closeOM,4000)}else toast('Please fill all fields correctly','error')};
 $$('#orderForm input,#orderForm textarea').forEach(i=>i.oninput=()=>i.closest('.fg').classList.remove('error'));
function subNL(){const e=$('#nlEmail');if(/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e.value.trim())){toast('Subscribed! 🎉');e.value=''}else toast('Enter a valid email','error')}
 $$('a[href^="#"]').forEach(a=>a.onclick=function(e){const h=this.getAttribute('href');if(!h||h==='#')return;e.preventDefault();const t=document.querySelector(h);if(t)scrollTo({top:t.offsetTop-80,behavior:'smooth'})});
let bgmOn=false,actx=null,bgmT=null;
function mkCtx(){if(!actx)actx=new(window.AudioContext||window.webkitAudioContext)();if(actx.state==='suspended')actx.resume();return actx}
function tone(f,st,d,tp='sine',v=0.1,dst){if(!f||f<=0)return;const o=actx.createOscillator(),g=actx.createGain();o.type=tp;o.frequency.setValueAtTime(f,st);g.gain.setValueAtTime(0,st);g.gain.linearRampToValueAtTime(v,st+.03);g.gain.setValueAtTime(v,st+d*.7);g.gain.exponentialRampToValueAtTime(.001,st+d);o.connect(g);g.connect(dst||actx.destination);o.start(st);o.stop(st+d+.01)}
function chord(fs,st,d,tp='triangle',v=.05){fs.forEach(f=>{if(f>0)tone(f,st,d,tp,v)})}
function playJingle(){const ctx=mkCtx(),m=actx.createGain();m.gain.setValueAtTime(.65,ctx.currentTime);m.connect(ctx.destination);let t=ctx.currentTime+.05;const b=60/142;chord([261.63,329.63,392],t,b*4,'triangle',.035);[{f:523.25,d:b*.8},{f:587.33,d:b*.6},{f:523.25,d:b*.4},{f:0,d:b*.2},{f:659.25,d:b},{f:659.25,d:b*.5},{f:783.99,d:b*.5},{f:698.46,d:b*.5},{f:659.25,d:b*.8}].forEach(n=>{if(n.f>0){tone(n.f,t,n.d*.9,'sine',.11,m);tone(n.f*.625,t,n.d*.9,'triangle',.025,m)}t+=n.d});t+=b*.5;[{f:392,d:b*.6},{f:440,d:b*.6},{f:523.25,d:b*1.2},{f:0,d:b*.3},{f:493.88,d:b*.6},{f:440,d:b*.6},{f:392,d:b*1.5}].forEach(n=>{if(n.f>0){tone(n.f,t,n.d*.9,'sine',.09,m);tone(n.f*.5,t,n.d*.9,'triangle',.02,m)}t+=n.d});let bt=ctx.currentTime+.05;[130.81,130.81,130.81,130.81,146.83,146.83,164.81,164.81,130.81,130.81,130.81,130.81].forEach(f=>{tone(f,bt,b*.85,'sine',.04,m);bt+=b*.75});let pt=ctx.currentTime+.05;for(let i=0;i<24;i++){const o=actx.createOscillator(),g=actx.createGain();o.type='square';o.frequency.setValueAtTime(i%4===0?800:600,pt);g.gain.setValueAtTime(.015,pt);g.gain.exponentialRampToValueAtTime(.001,pt+.04);o.connect(g);g.connect(m);o.start(pt);o.stop(pt+.05);pt+=b*.75}const dur=(t-ctx.currentTime)*1000;bgmT=setTimeout(()=>{if(bgmOn)playJingle()},dur+900)}
function startBGM(){mkCtx();bgmOn=true;$('#bgmIco').className='fas fa-pause';$('#bgmP').classList.add('bgm-playing');$('#eq').classList.remove('off');playJingle()}
function stopBGM(){bgmOn=false;$('#bgmIco').className='fas fa-play';$('#bgmP').classList.remove('bgm-playing');$('#eq').classList.add('off');if(bgmT){clearTimeout(bgmT);bgmT=null}}
 $('#bgmBtn').onclick=()=>bgmOn?stopBGM():startBGM();
</script>
