<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Somee Beverages — So Yummy!</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
        :root{
            --orange:#FF6B35;--pink:#FF1493;--teal:#00C9A7;--yellow:#FFD23F;
            --purple:#845EC2;--blue:#4B7BE5;--red:#FF4757;--dark:#0f0f1a;
            --dark-light:#1a1a2e;--dark-card:#22223a;--white:#fff;--light-bg:#FFF9F4;
            --cream:#FFF5E6;--text-dark:#0f0f1a;--text-gray:#666;--text-light:#999;
            --shadow-soft:0 8px 32px rgba(0,0,0,0.08);
            --shadow-medium:0 12px 40px rgba(0,0,0,0.12);
            --shadow-hard:0 20px 60px rgba(0,0,0,0.18);
            --shadow-glow-orange:0 8px 30px rgba(255,107,53,0.3);
            --shadow-glow-pink:0 8px 30px rgba(255,20,147,0.3);
            --radius:24px;--radius-sm:14px;--radius-xs:10px;
            --transition:all 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
        }
        html{scroll-behavior:smooth;overflow-x:hidden}
        body{font-family:'Poppins',sans-serif;color:var(--text-dark);background:var(--light-bg);overflow-x:hidden;line-height:1.7}
        h1,h2,h3,h4,h5,h6{font-family:'Baloo 2',cursive;line-height:1.15}
        a{text-decoration:none;color:inherit}
        img{max-width:100%;display:block}
        .container{max-width:1240px;margin:0 auto;padding:0 24px}
        .ambient-bg{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
        .ambient-orb{position:absolute;border-radius:50%;filter:blur(80px);opacity:0.12;animation:orbFloat 25s infinite ease-in-out}
        .ambient-orb:nth-child(1){width:500px;height:500px;background:var(--orange);top:-15%;left:-10%;animation-delay:0s}
        .ambient-orb:nth-child(2){width:400px;height:400px;background:var(--pink);top:40%;right:-10%;animation-delay:-8s;animation-duration:20s}
        .ambient-orb:nth-child(3){width:350px;height:350px;background:var(--teal);bottom:-10%;left:20%;animation-delay:-15s;animation-duration:22s}
        .ambient-orb:nth-child(4){width:300px;height:300px;background:var(--yellow);top:20%;left:50%;animation-delay:-5s;animation-duration:18s}
        @keyframes orbFloat{0%,100%{transform:translate(0,0) scale(1)}25%{transform:translate(60px,-100px) scale(1.15)}50%{transform:translate(-40px,-50px) scale(0.9)}75%{transform:translate(50px,70px) scale(1.1)}}
        .grain{position:fixed;inset:0;pointer-events:none;z-index:1;opacity:0.03;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E")}
        .navbar{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:18px 0;transition:var(--transition)}
        .navbar.scrolled{background:rgba(255,255,255,0.85);backdrop-filter:blur(24px) saturate(1.4);-webkit-backdrop-filter:blur(24px) saturate(1.4);box-shadow:0 1px 30px rgba(0,0,0,0.06);padding:12px 0}
        .navbar .container{display:flex;align-items:center;justify-content:space-between}
        .logo{display:flex;align-items:center;gap:14px;z-index:1001}
        .logo-img{height:50px;width:auto;border-radius:12px;object-fit:contain;transition:var(--transition)}
        .logo:hover .logo-img{transform:rotate(-8deg) scale(1.08)}
        .nav-links{display:flex;align-items:center;gap:6px;list-style:none}
        .nav-links a{padding:10px 20px;border-radius:50px;font-weight:500;font-size:.92rem;transition:var(--transition);letter-spacing:0.2px}
        .nav-links a:hover{color:var(--orange);background:rgba(255,107,53,0.08)}
        .nav-links a.active{color:#fff;background:linear-gradient(135deg,var(--orange),var(--pink));box-shadow:var(--shadow-glow-orange)}
        .nav-order-btn{padding:11px 26px!important;background:linear-gradient(135deg,var(--orange),var(--pink))!important;color:#fff!important;border-radius:50px!important;font-weight:600!important;box-shadow:var(--shadow-glow-orange);letter-spacing:0.3px!important}
        .nav-order-btn:hover{transform:translateY(-2px);box-shadow:var(--shadow-glow-pink)!important}
        .menu-toggle{display:none;flex-direction:column;gap:6px;cursor:pointer;z-index:1001;padding:6px}
        .menu-toggle span{width:26px;height:2.5px;background:var(--text-dark);border-radius:4px;transition:var(--transition)}
        .menu-toggle.active span:nth-child(1){transform:rotate(45deg) translate(5px,6px);background:var(--orange)}
        .menu-toggle.active span:nth-child(2){opacity:0;transform:scaleX(0)}
        .menu-toggle.active span:nth-child(3){transform:rotate(-45deg) translate(5px,-6px);background:var(--orange)}
        .hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding-top:90px;z-index:2}
        .hero-bg{position:absolute;inset:0;z-index:0;background:linear-gradient(160deg,#FFF9F4 0%,#FFF0F5 25%,#F0F7FF 50%,#F5FFF0 75%,#FFF9F4 100%)}
        .hero-bg::before{content:'';position:absolute;top:10%;right:5%;width:500px;height:500px;background:radial-gradient(circle,rgba(255,107,53,0.07),transparent 70%);border-radius:50%}
        .hero-bg::after{content:'';position:absolute;bottom:5%;left:5%;width:400px;height:400px;background:radial-gradient(circle,rgba(255,20,147,0.06),transparent 70%);border-radius:50%}
        .hero .container{position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:70px;align-items:center}
        .hero-content{animation:slideInL 1s ease-out}
        @keyframes slideInL{from{opacity:0;transform:translateX(-50px)}to{opacity:1;transform:translateX(0)}}
        .hero-chip{display:inline-flex;align-items:center;gap:8px;background:rgba(255,107,53,0.08);border:1px solid rgba(255,107,53,0.15);padding:8px 20px;border-radius:50px;font-size:.82rem;font-weight:600;color:var(--orange);margin-bottom:24px;animation:chipGlow 3s infinite}
        @keyframes chipGlow{0%,100%{box-shadow:0 0 0 0 rgba(255,107,53,0.15)}50%{box-shadow:0 0 0 12px rgba(255,107,53,0)}}
        .hero-chip i{font-size:.7rem}
        .hero-title{font-size:4.8rem;font-weight:800;color:var(--text-dark);margin-bottom:8px;line-height:1.02;letter-spacing:-1px}
        .hero-title .grad{background:linear-gradient(135deg,var(--orange),var(--pink),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;display:inline-block}
        .hero-tagline{font-family:'Baloo 2',cursive;font-size:2.2rem;color:var(--pink);margin-bottom:22px;animation:bounce 2.5s ease-in-out infinite}
        @keyframes bounce{0%,100%{transform:scale(1) rotate(0deg)}50%{transform:scale(1.04) rotate(-1deg)}}
        .hero-subtitle{font-size:1.05rem;color:var(--text-gray);margin-bottom:36px;max-width:460px;line-height:1.9}
        .hero-buttons{display:flex;gap:16px;flex-wrap:wrap}
        .btn-primary{display:inline-flex;align-items:center;gap:10px;padding:17px 38px;background:linear-gradient(135deg,var(--orange),var(--pink));color:#fff;border:none;border-radius:60px;font-size:1rem;font-weight:600;cursor:pointer;transition:var(--transition);box-shadow:var(--shadow-glow-orange);font-family:'Poppins',sans-serif;letter-spacing:0.3px}
        .btn-primary:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(255,107,53,0.45)}
        .btn-secondary{display:inline-flex;align-items:center;gap:10px;padding:17px 38px;background:#fff;color:var(--text-dark);border:2px solid rgba(0,0,0,0.06);border-radius:60px;font-size:1rem;font-weight:600;cursor:pointer;transition:var(--transition);font-family:'Poppins',sans-serif;letter-spacing:0.3px}
        .btn-secondary:hover{border-color:var(--orange);color:var(--orange);transform:translateY(-4px);box-shadow:var(--shadow-medium)}
        .hero-stats{display:flex;gap:44px;margin-top:44px;padding-top:30px;border-top:1px solid rgba(0,0,0,0.06)}
        .stat-item{text-align:center}
        .stat-number{font-family:'Baloo 2',cursive;font-size:2.2rem;font-weight:800;background:linear-gradient(135deg,var(--dark),var(--dark-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        .stat-label{font-size:.78rem;color:var(--text-light);font-weight:500;letter-spacing:0.5px;text-transform:uppercase;margin-top:2px}
        .hero-image{position:relative;animation:slideInR 1s ease-out .2s both}
        @keyframes slideInR{from{opacity:0;transform:translateX(50px)}to{opacity:1;transform:translateX(0)}}
        .hero-img-wrap{position:relative;width:100%;max-width:520px;margin:0 auto}
        .hero-img-wrap img{width:100%;border-radius:32px;box-shadow:var(--shadow-hard);object-fit:cover;aspect-ratio:4/5;transition:var(--transition)}
        .hero-img-wrap:hover img{transform:scale(1.02)}
        .hero-img-glow{position:absolute;inset:-20px;border-radius:40px;background:linear-gradient(135deg,rgba(255,107,53,0.15),rgba(255,20,147,0.1));filter:blur(40px);z-index:-1;animation:glowPulse 4s infinite}
        @keyframes glowPulse{0%,100%{opacity:.6;transform:scale(1)}50%{opacity:1;transform:scale(1.05)}}
        .float-card{position:absolute;background:rgba(255,255,255,0.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-radius:18px;padding:14px 20px;box-shadow:var(--shadow-medium);display:flex;align-items:center;gap:12px;border:1px solid rgba(255,255,255,0.8);animation:floatY 4s ease-in-out infinite}
        .float-card.c1{top:12%;left:-36px}
        .float-card.c2{bottom:18%;right:-36px;animation-delay:-2s}
        .float-card .fc-icon{width:44px;height:44px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:18px}
        .float-card.c1 .fc-icon{background:linear-gradient(135deg,var(--orange),#FF8C42);color:#fff;box-shadow:0 4px 12px rgba(255,107,53,0.3)}
        .float-card.c2 .fc-icon{background:linear-gradient(135deg,var(--teal),#00E5C7);color:#fff;box-shadow:0 4px 12px rgba(0,201,167,0.3)}
        .float-card .fc-text span{display:block;font-size:.72rem;color:var(--text-light);font-weight:500}
        .float-card .fc-text strong{font-size:.92rem;color:var(--text-dark)}
        @keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
        .section-header{text-align:center;margin-bottom:64px}
        .section-chip{display:inline-flex;align-items:center;gap:8px;padding:7px 20px;border-radius:50px;font-size:.78rem;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px}
        .section-chip.orange{background:rgba(255,107,53,0.08);color:var(--orange)}
        .section-chip.pink{background:rgba(255,20,147,0.08);color:var(--pink)}
        .section-chip.teal{background:rgba(0,201,167,0.08);color:var(--teal)}
        .section-chip.purple{background:rgba(132,94,194,0.08);color:var(--purple)}
        .section-title{font-size:3rem;font-weight:800;color:var(--text-dark);margin-bottom:14px;letter-spacing:-0.5px}
        .section-desc{font-size:1.05rem;color:var(--text-gray);max-width:580px;margin:0 auto;line-height:1.8}
        .about{padding:110px 0;position:relative;z-index:2}
        .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:70px;align-items:center}
        .about-img-box{position:relative}
        .about-img-box img{width:100%;border-radius:var(--radius);box-shadow:var(--shadow-medium);object-fit:cover;aspect-ratio:4/3;transition:var(--transition)}
        .about-img-box:hover img{transform:scale(1.02)}
        .about-img-border{position:absolute;width:100%;height:100%;top:18px;left:18px;border:3px solid var(--orange);border-radius:var(--radius);z-index:-1;opacity:0.2}
        .about-img-dots{position:absolute;bottom:-20px;right:-20px;width:100px;height:100px;background-image:radial-gradient(circle,rgba(255,107,53,0.2) 2px,transparent 2px);background-size:16px 16px;z-index:-1}
        .about-content h2{font-size:2.6rem;font-weight:800;color:var(--text-dark);margin-bottom:20px;letter-spacing:-0.5px}
        .about-content h2 span{background:linear-gradient(135deg,var(--orange),var(--pink));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        .about-content p{color:var(--text-gray);margin-bottom:14px;line-height:1.9}
        .about-pills{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:28px}
        .about-pill{display:flex;align-items:center;gap:12px;padding:14px 18px;background:#fff;border-radius:var(--radius-xs);box-shadow:var(--shadow-soft);transition:var(--transition);border:1px solid rgba(0,0,0,0.03)}
        .about-pill:hover{transform:translateY(-4px);box-shadow:var(--shadow-medium);border-color:rgba(255,107,53,0.1)}
        .about-pill i{width:38px;height:38px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:14px;color:#fff;flex-shrink:0}
        .about-pill:nth-child(1) i{background:linear-gradient(135deg,var(--orange),#FF8C42)}
        .about-pill:nth-child(2) i{background:linear-gradient(135deg,var(--pink),#FF69B4)}
        .about-pill:nth-child(3) i{background:linear-gradient(135deg,var(--teal),#00E5C7)}
        .about-pill:nth-child(4) i{background:linear-gradient(135deg,var(--purple),#A178DF)}
        .about-pill span{font-size:.85rem;font-weight:600;color:var(--text-dark)}
        .founder-box{margin-top:28px;padding:22px 24px;background:linear-gradient(135deg,rgba(255,107,53,0.04),rgba(255,20,147,0.04));border-left:4px solid var(--orange);border-radius:0 var(--radius-xs) var(--radius-xs) 0}
        .founder-box p{font-size:.92rem;color:var(--text-gray);margin-bottom:4px}
        .founder-box strong{font-size:1.15rem;color:var(--text-dark)}
        .products{padding:110px 0;background:linear-gradient(180deg,var(--light-bg),var(--cream));position:relative;z-index:2}
        .products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
        .product-card{background:#fff;border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-soft);transition:var(--transition);position:relative;border:1px solid rgba(0,0,0,0.03)}
        .product-card:hover{transform:translateY(-12px);box-shadow:var(--shadow-hard);border-color:rgba(255,107,53,0.1)}
        .product-tag{position:absolute;top:16px;left:16px;padding:6px 16px;border-radius:50px;font-size:.72rem;font-weight:700;color:#fff;z-index:2;letter-spacing:0.5px;text-transform:uppercase}
        .product-tag.bestseller{background:linear-gradient(135deg,var(--orange),var(--pink))}
        .product-tag.new{background:linear-gradient(135deg,var(--teal),#00E5C7)}
        .product-tag.popular{background:linear-gradient(135deg,var(--purple),#A178DF)}
        .product-tag.classic{background:linear-gradient(135deg,var(--blue),#6C8EF2)}
        .product-img{position:relative;overflow:hidden;height:260px;background:linear-gradient(135deg,#fafafa,#f5f5f5)}
        .product-img img{width:100%;height:100%;object-fit:contain;transition:var(--transition);padding:20px}
        .product-card:hover .product-img img{transform:scale(1.1)}
        .product-hover{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.35) 0%,transparent 60%);opacity:0;transition:var(--transition);display:flex;align-items:flex-end;justify-content:center;padding-bottom:24px}
        .product-card:hover .product-hover{opacity:1}
        .p-order-btn{padding:11px 28px;background:#fff;color:var(--orange);border:none;border-radius:50px;font-weight:700;font-size:.85rem;cursor:pointer;transition:var(--transition);transform:translateY(24px);font-family:'Poppins',sans-serif;box-shadow:0 6px 20px rgba(0,0,0,0.2);letter-spacing:0.3px}
        .product-card:hover .p-order-btn{transform:translateY(0)}
        .p-order-btn:hover{background:var(--orange);color:#fff}
        .p-info{padding:22px}
        .p-name{font-family:'Baloo 2',cursive;font-size:1.3rem;font-weight:700;color:var(--text-dark);margin-bottom:6px}
        .p-desc{font-size:.84rem;color:var(--text-light);margin-bottom:14px;line-height:1.6}
        .p-bottom{display:flex;align-items:center;justify-content:space-between}
        .p-price{font-family:'Baloo 2',cursive;font-size:1.5rem;font-weight:800;color:var(--orange)}
        .p-stars{display:flex;align-items:center;gap:3px;font-size:.8rem;color:var(--yellow)}
        .p-stars span{color:var(--text-light);font-size:.8rem;margin-left:4px}
        .journey{padding:90px 0;position:relative;z-index:2}
        .journey-box{background:linear-gradient(145deg,var(--dark) 0%,var(--dark-light) 50%,#1e1e38 100%);border-radius:32px;padding:70px 60px;position:relative;overflow:hidden}
        .journey-box::before{content:'';position:absolute;top:-40%;right:-15%;width:550px;height:550px;background:radial-gradient(circle,rgba(255,107,53,0.12),transparent 70%);border-radius:50%}
        .journey-box::after{content:'';position:absolute;bottom:-30%;left:-10%;width:400px;height:400px;background:radial-gradient(circle,rgba(255,20,147,0.08),transparent 70%);border-radius:50%}
        .journey-inner{position:relative;z-index:1;text-align:center;max-width:720px;margin:0 auto}
        .journey-inner h2{font-size:3rem;font-weight:800;color:#fff;margin-bottom:16px;letter-spacing:-0.5px}
        .journey-inner h2 span{background:linear-gradient(135deg,var(--orange),var(--yellow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        .journey-inner>p{color:rgba(255,255,255,0.6);font-size:1.08rem;line-height:1.9;margin-bottom:40px}
        .journey-steps{display:flex;justify-content:center;gap:36px;flex-wrap:wrap}
        .j-step{text-align:center;flex:1;min-width:140px}
        .j-step-icon{width:72px;height:72px;border-radius:22px;display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 14px;color:#fff;transition:var(--transition)}
        .j-step:hover .j-step-icon{transform:translateY(-6px) rotate(-5deg)}
        .j-step:nth-child(1) .j-step-icon{background:linear-gradient(135deg,var(--orange),#FF8C42);box-shadow:0 8px 24px rgba(255,107,53,0.3)}
        .j-step:nth-child(2) .j-step-icon{background:linear-gradient(135deg,var(--pink),#FF69B4);box-shadow:0 8px 24px rgba(255,20,147,0.3)}
        .j-step:nth-child(3) .j-step-icon{background:linear-gradient(135deg,var(--teal),#00E5C7);box-shadow:0 8px 24px rgba(0,201,167,0.3)}
        .j-step:nth-child(4) .j-step-icon{background:linear-gradient(135deg,var(--yellow),#FFA500);box-shadow:0 8px 24px rgba(255,210,63,0.3)}
        .j-step h4{color:#fff;font-size:1.02rem;margin-bottom:4px}
        .j-step p{color:rgba(255,255,255,0.45);font-size:.78rem!important;margin-bottom:0!important}
        .gallery{padding:110px 0;position:relative;z-index:2}
        .gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(2,260px);gap:20px}
        .gallery-item{border-radius:var(--radius);overflow:hidden;position:relative;cursor:pointer}
        .gallery-item:nth-child(1){grid-column:span 2;grid-row:span 2}
        .gallery-item:nth-child(4){grid-column:span 2}
        .gallery-item img{width:100%;height:100%;object-fit:cover;transition:var(--transition)}
        .gallery-item:hover img{transform:scale(1.08)}
        .gallery-item::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.45) 0%,transparent 50%);opacity:0;transition:var(--transition)}
        .gallery-item:hover::after{opacity:1}
        .gallery-label{position:absolute;bottom:20px;left:20px;z-index:2;color:#fff;font-weight:600;font-size:.92rem;opacity:0;transform:translateY(10px);transition:var(--transition)}
        .gallery-item:hover .gallery-label{opacity:1;transform:translateY(0)}
        .contact{padding:110px 0;background:linear-gradient(180deg,var(--cream),var(--light-bg));position:relative;z-index:2}
        .contact-grid{display:grid;grid-template-columns:1fr 1.3fr;gap:56px;align-items:start}
        .contact-info h3{font-size:1.9rem;font-weight:700;color:var(--text-dark);margin-bottom:16px}
        .contact-info>p{color:var(--text-gray);margin-bottom:32px;line-height:1.9}
        .c-details{display:flex;flex-direction:column;gap:18px}
        .c-detail{display:flex;align-items:center;gap:16px;padding:18px;background:#fff;border-radius:var(--radius-xs);box-shadow:var(--shadow-soft);transition:var(--transition);border:1px solid rgba(0,0,0,0.03)}
        .c-detail:hover{transform:translateX(6px);box-shadow:var(--shadow-medium);border-color:rgba(255,107,53,0.1)}
        .c-detail i{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:18px;color:#fff;flex-shrink:0}
        .c-detail:nth-child(1) i{background:linear-gradient(135deg,var(--orange),var(--pink))}
        .c-detail:nth-child(2) i{background:linear-gradient(135deg,var(--teal),#00E5C7)}
        .c-detail:nth-child(3) i{background:linear-gradient(135deg,var(--purple),#A178DF)}
        .c-detail .c-text span{font-weight:600;color:var(--text-dark);font-size:.95rem;display:block}
