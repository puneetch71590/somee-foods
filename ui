<script>
const $=s=>document.querySelector(s),$$=s=>document.querySelectorAll(s);
const menuT=$('#menuToggle'),navL=$('#navLinks');
menuT.onclick=()=>{menuT.classList.toggle('active');navL.classList.toggle('active')};
navL.querySelectorAll('a').forEach(l=>l.onclick=()=>{if(l.id!=='navOrderBtn'){menuT.classList.remove('active');navL.classList.remove('active')}});
document.onclick=e=>{if(!navL.contains(e.target)&&!menuT.contains(e.target)){menuT.classList.remove('active');navL.classList.remove('active')}};
const nb=$('#navbar');window.onscroll=()=>{nb.classList.toggle('scrolled',scrollY>50);$('#stt').classList.toggle('visible',scrollY>500)};
const secs=$$('section[id]');window.addEventListener('scroll',()=>{let c='';secs.forEach(s=>{if(scrollY>=s.offsetTop-100)c=s.id});navL.querySelectorAll('a:not(.nav-order-btn)').forEach(l=>{l.classList.remove('active');if(l.getAttribute('href')==='#'+c)l.classList.add('active')})});
 $('#stt').onclick=()=>scrollTo({top:0,behavior:'smooth'});
const rObs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('v')}),{threshold:.1,rootMargin:'0px 0px -40px 0px'});
 $$('.rv,.rv-l,.rv-r').forEach(el=>rObs.observe(el));
const hObs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){$$('.stat-number').forEach(s=>{const t=+s.dataset.count,sx=s.textContent.replace(/[0-9]/g,'');let c=0;const inc=t/55;const tm=setInterval(()=>{c+=inc;if(c>=t){c=t;clearInterval(tm)}s.textContent=Math.floor(c).toLocaleString()+sx},28)});hObs.disconnect()}}),{threshold:.3});
hObs.observe($('.hero'));
function toast(m,t='success'){const el=$('#toast'),msg=$('#toastM'),ic=el.querySelector('i');el.className='toast '+t;msg.textContent=m;ic.className=t==='success'?'fas fa-check-circle':'fas fa-exclamation-circle';el.classList.add('show');setTimeout(()=>el.classList.remove('show'),3500)}
 $('#contactForm').onsubmit=e=>{e.preventDefault();let ok=true;[{i:'cName',v:x=>x.trim().length>0},{i:'cEmail',v:x=>/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(x)},{i:'cMsg',v:x=>x.trim().length>0}].forEach(f=>{const inp=$('#'+f.i),g=inp.closest('.fg');if(!f.v(inp.value)){g.classList.add('error');ok=false}else g.classList.remove('error')});if(ok){$('#contactForm').style.display='none';$('#cSuccess').classList.add('show');toast('Message sent to sohamdada@gmail.com!');setTimeout(()=>{$('#contactForm').style.display='block';$('#cSuccess').classList.remove('show');$('#contactForm').reset()},5000)}else toast('Please fill all fields correctly','error')};
 $$('#contactForm input,#contactForm textarea').forEach(i=>i.oninput=()=>i.closest('.fg').classList.remove('error'));
const om=$('#orderModal'),of=$('#orderForm'),os=$('#oSuccess');
function openOM(n,p){$('#pmName').textContent=n+' — '+p;$('#oProd').value=n;$('#oPrice').value=p;om.classList.add('active');document.body.style.overflow='hidden'}
 $('#navOrderBtn').onclick=e=>{e.preventDefault();$('#pmName').textContent='Custom Order';$('#oProd').value='Custom';$('#oPrice').value='';om.classList.add('active');document.body.style.overflow='hidden';menuT.classList.remove('active');navL.classList.remove('active')};
